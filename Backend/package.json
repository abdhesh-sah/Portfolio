{
  "name": "portfolio-backend",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch --exclude drizzle --import ./src/instrument.ts src/index.ts",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "type-check": "tsc --noEmit",
    "build": "npm run build --prefix .. -w @portfolio/shared && tsc --project tsconfig.json",
    "start": "node --import ./dist/src/instrument.js ./dist/src/index.js",
    "migrate": "npx drizzle-kit migrate",
    "generate": "npx drizzle-kit generate",
    "db:status": "npx drizzle-kit check",
    "db:reset": "npx tsx src/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e:server": "cross-env NODE_ENV=test PORT=5005 HOST=127.0.0.1 tsx src/index.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@openrouter/sdk": "^0.13.7",
    "@portfolio/shared": "*",
    "@react-pdf/renderer": "^4.3.2",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/node": "^10.65.0",
    "@sentry/profiling-node": "^10.65.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.10",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.2",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "file-type": "^22.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "isomorphic-dompurify": "^3.12.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rate-limit-redis": "^4.3.1",
    "react": "^19.2.3",
    "resend": "^6.7.0",
    "satori": "^0.26.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.9",
    "globals": "^17.4.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.28.1"
  },
  "engines": {
    "node": "22.x"
  }
}
