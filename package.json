{
    "name": "portfolio-monorepo",
    "version": "2.0.0",
    "private": true,
    "description": "Portfolio v8 Monorepo",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^26.1.1",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "concurrently": "^10.0.3",
        "eslint": "^10.6.0",
        "jsdom": "^29.0.1",
        "tinyexec": "^1.2.4",
        "tsx": "^4.23.1",
        "typescript": "^5.7.3"
    },
    "workspaces": [
        "Backend",
        "Frontend",
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "dev:backend": "npm run dev -w Backend",
        "dev:frontend": "npm run dev -w Frontend",
        "dev:b": "npm run dev:backend",
        "dev:f": "npm run dev:frontend",
        "build:shared": "npm run build -w @portfolio/shared",
        "build:backend": "npm run build:shared && npm run build -w Backend",
        "build:frontend": "npm run build:shared && npm run build -w Frontend",
        "test:backend": "npm run build:shared && npm run test -w Backend",
        "test:frontend": "npm run build:shared && npm run test -w Frontend",
        "test:all": "npm run build:shared && npm run test --workspaces",
        "lint:backend": "npm run lint -w Backend",
        "lint:frontend": "npm run lint -w Frontend",
        "lint:all": "npm run lint --workspaces",
        "type-check:backend": "npm run build:shared && npm run type-check -w Backend",
        "type-check:frontend": "npm run build:shared && npm run type-check -w Frontend",
        "type-check:all": "npm run build:shared && npm run type-check --workspaces",
        "build": "npm run build:backend && npm run build:frontend"
    },
    "overrides": {
        "zod": "^3.25.76",
        "ioredis": "5.10.0",
        "multer-storage-cloudinary": {
            "cloudinary": "^2.0.0"
        },
        "@types/express": "5.0.6",
        "@types/express-serve-static-core": "5.0.6",
        "serialize-javascript": "^7.0.4",
        "esbuild": "^0.25.0",
        "flatted": "^3.4.2",
        "fast-xml-parser": "^5.4.1",
        "uuid": "^11.1.1"
    },
    "dependencies": {
        "axios": "^1.14.0"
    },
    "optionalDependencies": {
        "@esbuild/linux-x64": "0.28.1",
        "@rolldown/binding-linux-x64-gnu": "1.0.3",
        "@rollup/rollup-linux-x64-gnu": "4.62.2",
        "@tailwindcss/oxide-linux-x64-gnu": "4.2.2",
        "lightningcss-linux-x64-gnu": "1.32.0"
    },
    "engines": {
        "node": "22.x"
    }
}
